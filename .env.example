# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=candidate_ranking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-secure-random-hex-string

# ── Ollama ────────────────────────────────────────────────────────────────────
# Options: llama3, gemma2, mistral, phi3, etc.
OLLAMA_MODEL=llama3

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
